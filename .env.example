# API Keys for Strospeak Voice App
# Copy this file to .env and fill in your actual values
# .env should be added to .gitignore (already done)

# Groq API Configuration
STRO_SPEAK_AI_API_KEY=your_groq_api_key_here
STRO_SPEAK_AI_BASE_URL=https://api.groq.com/openai/v1

# Transcription API Configuration (optional, will fall back to AI API if not set)
STRO_SPEAK_TRANSCRIPTION_API_KEY=
STRO_SPEAK_TRANSCRIPTION_BASE_URL=
